# Verdict — Environment Variables
# Copy this file to .env and fill in your keys.
# Never commit .env to version control.

# ── LLM Provider Keys ──────────────────────────────────────────────────────
# At least one provider key is required for running evaluations.

# OpenAI (for gpt-4o, gpt-4o-mini)
OPENAI_API_KEY=sk-...

# Anthropic (for claude-3-5-sonnet, claude-3-haiku)
ANTHROPIC_API_KEY=sk-ant-...

# Together AI (for open-source models via LiteLLM)
TOGETHER_API_KEY=...

# Groq (for fast Llama/Mixtral inference)
GROQ_API_KEY=...

# ── Verdict Settings ──────────────────────────────────────────────────────
# Default target model used when --model is not specified
VERDICT_TARGET_MODEL=gpt-4o-mini

# Default judge model
VERDICT_JUDGE_MODEL=gpt-4o-mini

# API server host/port
VERDICT_API_HOST=0.0.0.0
VERDICT_API_PORT=8080

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
